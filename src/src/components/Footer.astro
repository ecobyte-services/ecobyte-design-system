---
const year = new Date().getFullYear();
---

<footer
  class="border-t mt-20"
  style="background: var(--bg-surface); border-color: var(--border);"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">

      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <img
            src="/brand/logo/ecobyte-as-color-symbol-transparent.png"
            alt="EcoByte AS"
            class="h-12 w-auto"
          />
          <span class="font-semibold text-base" style="color: var(--text-primary);">EcoByte AS</span>
        </div>
        <p class="text-sm max-w-xs" style="color: var(--text-secondary);">
          Premium sustainable infrastructure for the production industry.
          Infrastructure that just works — so you can focus on what you do best.
        </p>
        <div class="mt-4 flex gap-3">
          <a
            href="#"
            aria-label="LinkedIn"
            class="p-2 rounded-lg border transition-colors hover:border-[#1B5E3A] hover:text-[#1B5E3A]"
            style="border-color: var(--border); color: var(--text-secondary);"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77Z" />
            </svg>
          </a>
          <a
            href="#"
            aria-label="GitHub"
            class="p-2 rounded-lg border transition-colors hover:border-[#1B5E3A] hover:text-[#1B5E3A]"
            style="border-color: var(--border); color: var(--text-secondary);"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Design System -->
      <div>
        <h3 class="text-sm font-semibold mb-3" style="color: var(--text-primary);">Design System</h3>
        <ul class="space-y-2 text-sm" style="color: var(--text-secondary);">
          <li><a href="/" class="hover:text-[#1B5E3A] transition-colors">Overview</a></li>
          <li><a href="/components" class="hover:text-[#1B5E3A] transition-colors">Components</a></li>
          <li><a href="/#colors" class="hover:text-[#1B5E3A] transition-colors">Color Palette</a></li>
          <li><a href="/#typography" class="hover:text-[#1B5E3A] transition-colors">Typography</a></li>
        </ul>
      </div>

      <!-- ACME Demo -->
      <div>
        <h3 class="text-sm font-semibold mb-3" style="color: var(--text-primary);">ACME Demo</h3>
        <ul class="space-y-2 text-sm" style="color: var(--text-secondary);">
          <li><a href="/acme" class="hover:text-[#1B5E3A] transition-colors">Landing Page</a></li>
          <li><a href="/acme/dashboard" class="hover:text-[#1B5E3A] transition-colors">Dashboard</a></li>
          <li><a href="/acme/blog" class="hover:text-[#1B5E3A] transition-colors">Blog</a></li>
        </ul>
      </div>
    </div>

    <div
      class="mt-10 pt-6 border-t flex flex-col sm:flex-row justify-between items-center gap-2 text-xs"
      style="border-color: var(--border); color: var(--text-secondary);"
    >
      <span>© {year} EcoByte AS. All rights reserved.</span>
      <span>Design System Demo — Built with Astro + Tailwind CSS</span>
    </div>
  </div>
</footer>
