---
const navLinks = [
  { href: '/',            label: 'Design System' },
  { href: '/components',  label: 'Components' },
  { href: '/acme',        label: 'ACME Landing' },
  { href: '/acme/dashboard', label: 'Dashboard' },
  { href: '/acme/blog',   label: 'Blog' },
];

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header
  class="sticky top-0 z-50 border-b"
  style="background: var(--bg-surface); border-color: var(--border);"
>
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0">
      <img
        src="/brand/logo/ecobyte-as-color-symbol-transparent.png"
        alt="EcoByte AS"
        class="h-12 w-auto"
      />
      <span
        class="text-base font-semibold tracking-tight hidden sm:block"
        style="color: var(--text-primary);"
      >
        EcoByte <span class="text-forest" style="color: #1B5E3A;">Design System</span>
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-1" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={[
              'px-3 py-1.5 rounded-md text-sm font-medium transition-colors duration-150',
              isActive(link.href)
                ? 'bg-forest text-white'
                : 'hover:bg-[var(--bg-muted)]',
            ].join(' ')}
            style={isActive(link.href) ? 'background-color: #1B5E3A; color: #fff;' : `color: var(--text-secondary);`}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side: dark mode + mobile menu -->
    <div class="flex items-center gap-2">
      <!-- Dark mode toggle -->
      <button
        data-dark-toggle
        aria-label="Toggle dark mode"
        class="p-2 rounded-lg transition-colors hover:bg-[var(--bg-muted)] cursor-pointer"
        style="color: var(--text-secondary);"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="hidden dark:block w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="block dark:hidden w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      </button>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden p-2 rounded-lg transition-colors hover:bg-[var(--bg-muted)] cursor-pointer"
        style="color: var(--text-secondary);"
      >
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t px-4 py-3 space-y-1"
    style="border-color: var(--border); background: var(--bg-surface);"
  >
    {navLinks.map((link) => (
      <a
        href={link.href}
        class={[
          'block px-3 py-2 rounded-md text-sm font-medium transition-colors',
          isActive(link.href)
            ? 'text-white'
            : '',
        ].join(' ')}
        style={isActive(link.href)
          ? 'background-color: #1B5E3A; color: #fff;'
          : `color: var(--text-primary);`
        }
        aria-current={isActive(link.href) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
