---
import BaseLayout from '@/layouts/BaseLayout.astro';

const colors = [
  {
    group: 'Canopy — Greens',
    swatches: [
      { name: 'Forest Green', token: '--color-forest',     hex: '#1B5E3A', usage: 'Primary, headings, CTAs' },
      { name: 'Medium Green', token: '--color-med-green',  hex: '#4A7C4F', usage: 'Secondary surfaces' },
      { name: 'Sage Olive',   token: '--color-sage',       hex: '#7A9A5E', usage: 'Light accent, backgrounds' },
      { name: 'Dark Olive',   token: '--color-olive',      hex: '#8B8C3E', usage: 'Transitional accent' },
      { name: 'Golden Amber', token: '--color-gold',       hex: '#C9A032', usage: 'Warm accent, highlights' },
    ],
  },
  {
    group: 'Roots — Copper',
    swatches: [
      { name: 'Light Copper', token: '--color-copper-light', hex: '#D4945A', usage: 'Light circuit color' },
      { name: 'Medium Copper',token: '--color-copper',       hex: '#C07840', usage: 'Primary circuit color' },
      { name: 'Burnt Sienna', token: '--color-sienna',       hex: '#A05A30', usage: 'Dark circuit color' },
      { name: 'Dark Brown',   token: '--color-brown',        hex: '#7A5030', usage: 'Darkest accent' },
    ],
  },
  {
    group: 'Neutral',
    swatches: [
      { name: 'Charcoal',   token: '--color-charcoal',   hex: '#333333', usage: 'Body text' },
      { name: 'Warm Grey',  token: '--color-warm-grey',  hex: '#888888', usage: 'Secondary text' },
      { name: 'Off-White',  token: '--color-off-white',  hex: '#F8F8F6', usage: 'Warm background' },
      { name: 'White',      token: '--',                  hex: '#FFFFFF', usage: 'Pure background' },
    ],
  },
];

const typeScale = [
  { label: 'Display',  class: 'text-5xl font-semibold', sample: 'The forest breathes.' },
  { label: 'H1',       class: 'text-4xl font-semibold', sample: 'Infrastructure that just works.' },
  { label: 'H2',       class: 'text-3xl font-semibold', sample: 'Sustainable by design.' },
  { label: 'H3',       class: 'text-2xl font-semibold', sample: 'Roots in technology.' },
  { label: 'H4',       class: 'text-xl font-semibold',  sample: 'Connecting the ecosystem.' },
  { label: 'Body Lg',  class: 'text-lg font-normal',    sample: 'We deliver the tech beneath the surface, so your core business can flourish above.' },
  { label: 'Body',     class: 'text-base font-normal',  sample: 'Premium sustainable infrastructure for the production industry. Professional, warm, accessible.' },
  { label: 'Small',    class: 'text-sm font-normal',    sample: 'Secondary text, labels, captions, metadata.' },
  { label: 'XSmall',   class: 'text-xs font-normal',    sample: 'Legal text, timestamps, micro-copy.' },
];

const spacingScale = [2, 4, 8, 12, 16, 20, 24, 32, 40, 48, 64];
---

<BaseLayout title="Design System Overview">
  <!-- ── Hero ─────────────────────────────────── -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <!-- Background gradient -->
    <div
      class="absolute inset-0 -z-10"
      style="background: linear-gradient(135deg, #1B5E3A 0%, #4A7C4F 60%, #7A9A5E 100%);"
      aria-hidden="true"
    ></div>
    <div
      class="absolute inset-0 -z-10 opacity-10"
      style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");"
      aria-hidden="true"
    ></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center text-white">
      <img
        src="/brand/logo/ecobyte-as-white-symbol-transparent.png"
        alt=""
        class="mx-auto mb-8 h-20 w-auto"
        aria-hidden="true"
      />
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight mb-6 text-balance">
        EcoByte Design System
      </h1>
      <p class="text-lg sm:text-xl max-w-2xl mx-auto mb-10 text-white/80 text-pretty">
        A living design language for EcoByte AS — colors, typography, spacing, and
        components that power every touchpoint.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a
          href="/components"
          class="px-6 py-3 rounded-lg font-semibold text-sm transition-all hover:-translate-y-0.5 shadow-lg"
          style="background: #C9A032; color: #1B2820;"
        >
          Component Gallery →
        </a>
        <a
          href="/acme"
          class="px-6 py-3 rounded-lg font-semibold text-sm border border-white/30 hover:bg-white/10 transition-all"
          style="color: white;"
        >
          See ACME Demo
        </a>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- ── Intro ─────────────────────────────── -->
    <section class="py-16 border-b" style="border-color: var(--border);">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            icon: 'park',
            title: 'Nature-meets-technology',
            desc: 'Our palette draws from the forest canopy above and circuit roots below — organic warmth meets technical precision.',
          },
          {
            icon: 'bolt',
            title: 'Professional & warm',
            desc: 'Confident without arrogance. Technically competent but understandable. "We understand your world."',
          },
          {
            icon: 'accessibility_new',
            title: 'Accessible by default',
            desc: 'Every color pair meets WCAG AA contrast. Semantic HTML. Keyboard navigable. Dark mode built-in.',
          },
        ].map((card) => (
          <div
            class="rounded-xl p-6 border card-hover"
            style="background: var(--bg-surface); border-color: var(--border);"
          >
            <div class="mb-3" aria-hidden="true"><span class="material-symbols-outlined" style="font-size: 36px; color: #4A7C4F;">{card.icon}</span></div>
            <h3 class="font-semibold text-base mb-2" style="color: var(--text-primary);">{card.title}</h3>
            <p class="text-sm" style="color: var(--text-secondary);">{card.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Colors ─────────────────────────────── -->
    <section id="colors" class="py-16 border-b" style="border-color: var(--border);">
      <div class="mb-10">
        <span class="text-xs font-semibold tracking-widest uppercase" style="color: #1B5E3A;">Design Tokens</span>
        <h2 class="text-3xl font-semibold mt-1 mb-3" style="color: var(--text-primary);">Color Palette</h2>
        <p class="text-sm max-w-xl" style="color: var(--text-secondary);">
          Click any swatch to copy the hex value. CSS custom properties follow the EcoByte naming convention.
        </p>
      </div>

      <div class="space-y-10">
        {colors.map((group) => (
          <div>
            <h3 class="text-sm font-semibold mb-4 uppercase tracking-wider" style="color: var(--text-secondary);">
              {group.group}
            </h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
              {group.swatches.map((s) => (
                <button
                  data-copy={s.hex}
                  class="group text-left rounded-xl overflow-hidden border transition-all hover:scale-105 hover:shadow-lg focus-visible:ring-2 ring-[#1B5E3A] ring-offset-2 cursor-pointer"
                  style={`border-color: var(--border); background: var(--bg-surface);`}
                  title={`Copy ${s.hex}`}
                  type="button"
                >
                  <div
                    class="h-20 w-full flex items-end p-2"
                    style={`background-color: ${s.hex};`}
                  >
                    <span
                      class="opacity-0 group-hover:opacity-100 text-xs px-1.5 py-0.5 rounded font-mono transition-opacity"
                      style="background: rgba(0,0,0,0.5); color: #fff;"
                    >
                      Click to copy
                    </span>
                  </div>
                  <div class="p-3">
                    <p class="text-xs font-semibold mb-0.5 truncate" style="color: var(--text-primary);">{s.name}</p>
                    <p
                      class="text-xs font-mono"
                      data-copy-tip
                      style="color: var(--text-secondary);"
                    >
                      {s.hex}
                    </p>
                    <p class="text-xs mt-1 line-clamp-2" style="color: var(--text-secondary);">{s.usage}</p>
                  </div>
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Typography ─────────────────────────── -->
    <section id="typography" class="py-16 border-b" style="border-color: var(--border);">
      <div class="mb-10">
        <span class="text-xs font-semibold tracking-widest uppercase" style="color: #1B5E3A;">Design Tokens</span>
        <h2 class="text-3xl font-semibold mt-1 mb-3" style="color: var(--text-primary);">Typography Scale</h2>
        <p class="text-sm max-w-xl" style="color: var(--text-secondary);">
          Nunito Sans — a geometric sans-serif chosen for its warmth and readability.
          SemiBold (600) for headings, Regular (400) for body, Light (300) for secondary text.
        </p>
      </div>

      <div
        class="rounded-xl border overflow-hidden divide-y"
        style="border-color: var(--border); divide-color: var(--border); background: var(--bg-surface);"
      >
        {typeScale.map((t) => (
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 px-6 py-5">
            <div class="w-20 shrink-0">
              <span
                class="text-xs font-semibold px-2 py-0.5 rounded"
                style="background: var(--bg-muted); color: var(--text-secondary);"
              >
                {t.label}
              </span>
            </div>
            <p
              class={`${t.class} leading-tight`}
              style="color: var(--text-primary);"
            >
              {t.sample}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Spacing ─────────────────────────────── -->
    <section id="spacing" class="py-16 border-b" style="border-color: var(--border);">
      <div class="mb-10">
        <span class="text-xs font-semibold tracking-widest uppercase" style="color: #1B5E3A;">Design Tokens</span>
        <h2 class="text-3xl font-semibold mt-1 mb-3" style="color: var(--text-primary);">Spacing Scale</h2>
        <p class="text-sm max-w-xl" style="color: var(--text-secondary);">
          Based on a 4px baseline grid (1 unit = 0.25rem). Use multiples for consistent rhythm.
        </p>
      </div>

      <div class="space-y-3">
        {spacingScale.map((n) => (
          <div class="flex items-center gap-4">
            <div class="w-16 text-right">
              <code class="text-xs" style="color: var(--text-secondary);">space-{n}</code>
            </div>
            <div class="w-12 text-right">
              <span class="text-xs font-mono" style="color: var(--text-secondary);">{n * 4}px</span>
            </div>
            <div
              class="h-5 rounded"
              style={`width: ${n * 4}px; background: #1B5E3A;`}
            ></div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Gradients ──────────────────────────── -->
    <section class="py-16 border-b" style="border-color: var(--border);">
      <div class="mb-10">
        <span class="text-xs font-semibold tracking-widest uppercase" style="color: #1B5E3A;">Design Tokens</span>
        <h2 class="text-3xl font-semibold mt-1 mb-3" style="color: var(--text-primary);">Gradients &amp; Effects</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          {
            label: 'Forest Canopy',
            style: 'background: linear-gradient(135deg, #1B5E3A 0%, #4A7C4F 100%);',
            code: 'gradient-forest',
          },
          {
            label: 'Sage Meadow',
            style: 'background: linear-gradient(135deg, #4A7C4F 0%, #7A9A5E 100%);',
            code: 'gradient-sage',
          },
          {
            label: 'Golden Amber',
            style: 'background: linear-gradient(135deg, #C9A032 0%, #D4945A 100%);',
            code: 'gradient-gold',
          },
          {
            label: 'Copper Root',
            style: 'background: linear-gradient(135deg, #C07840 0%, #A05A30 100%);',
            code: 'gradient-copper',
          },
          {
            label: 'Earth',
            style: 'background: linear-gradient(135deg, #1B5E3A 0%, #C9A032 100%);',
            code: 'gradient-earth',
          },
          {
            label: 'Twilight',
            style: 'background: linear-gradient(135deg, #1B5E3A 0%, #8B8C3E 50%, #C9A032 100%);',
            code: 'gradient-twilight',
          },
        ].map((g) => (
          <div class="rounded-xl overflow-hidden border card-hover" style="border-color: var(--border);">
            <div class="h-24 w-full" style={g.style}></div>
            <div class="px-4 py-3" style="background: var(--bg-surface);">
              <p class="text-sm font-semibold" style="color: var(--text-primary);">{g.label}</p>
              <code class="text-xs" style="color: var(--text-secondary);">.{g.code}</code>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Icons / Shadows ─────────────────────── -->
    <section class="py-16">
      <div class="mb-10">
        <span class="text-xs font-semibold tracking-widest uppercase" style="color: #1B5E3A;">Design Tokens</span>
        <h2 class="text-3xl font-semibold mt-1 mb-3" style="color: var(--text-primary);">Elevation &amp; Shadows</h2>
      </div>
      <div class="flex flex-wrap gap-8 items-end">
        {[
          { label: 'shadow-sm',  style: 'box-shadow: 0 1px 2px rgba(27,94,58,0.06);' },
          { label: 'shadow',     style: 'box-shadow: 0 2px 8px rgba(27,94,58,0.10);' },
          { label: 'shadow-md',  style: 'box-shadow: 0 4px 16px rgba(27,94,58,0.12);' },
          { label: 'shadow-lg',  style: 'box-shadow: 0 8px 24px rgba(27,94,58,0.15);' },
          { label: 'shadow-xl',  style: 'box-shadow: 0 16px 40px rgba(27,94,58,0.18);' },
        ].map((s, i) => (
          <div class="text-center">
            <div
              class="rounded-xl mb-3"
              style={`width: ${60 + i * 16}px; height: ${60 + i * 16}px; background: var(--bg-surface); ${s.style}`}
            ></div>
            <code class="text-xs" style="color: var(--text-secondary);">{s.label}</code>
          </div>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
